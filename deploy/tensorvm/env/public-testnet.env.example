# Copy to /etc/tensorvm/public-testnet.env and replace every example value before launch.
TVMD_LISTEN=127.0.0.1:8545
TVMD_P2P_LISTEN=/ip4/0.0.0.0/tcp/4001
TVMD_DATA_DIR=/var/lib/tensorvm
TVMD_AUTH_TOKEN=replace-with-high-entropy-token
TVMD_MAX_REQUESTS=0

# Before starting non-bootstrap nodes, seed the durable libp2p peer book with:
# tvmd service peer add --data-dir "$TVMD_DATA_DIR" --peer-id "$BOOTSTRAP_PEER_ID" --address /dns/bootstrap.tensorvm.net/tcp/4001
